local espEnabled = false
local espLabels = {}
local selectedItem = nil

local function getPrimaryPart(item)
    if not item:IsA("Model") then return nil end
    if item:FindFirstChild("Primary") and item.Primary:IsA("BasePart") then
        return item.Primary
    end
    for _, child in ipairs(item:GetDescendants()) do
        if child:IsA("BasePart") then
            return child
        end
    end
    return nil
end

local function createEsp(item)
    local part = getPrimaryPart(item)
    if not part then return end
    local bb = Instance.new("BillboardGui")
    bb.Name = "ItemESP"
    bb.AlwaysOnTop = true
    bb.Size = UDim2.new(0, 200, 0, 40)
    bb.StudsOffset = Vector3.new(0, 2.5, 0)
    bb.Adornee = part
    bb.Parent = part
    local nl = Instance.new("TextLabel")
    nl.Size = UDim2.new(1, 0, 0.5, 0)
    nl.BackgroundTransparency = 1
    nl.Text = item.Name
    nl.TextColor3 = Color3.fromRGB(255, 255, 0)
    nl.TextStrokeTransparency = 0
    nl.TextSize = 14
    nl.Font = Enum.Font.SourceSansBold
    nl.Parent = bb
    local dl = Instance.new("TextLabel")
    dl.Size = UDim2.new(1, 0, 0.5, 0)
    dl.Position = UDim2.new(0, 0, 0.5, 0)
    dl.BackgroundTransparency = 1
    dl.Text = "0m"
    dl.TextColor3 = Color3.fromRGB(0, 255, 255)
    dl.TextStrokeTransparency = 0
    dl.TextSize = 12
    dl.Font = Enum.Font.SourceSansBold
    dl.Parent = bb
    espLabels[item] = {bb = bb, dl = dl, part = part}
end

local function clearEsp()
    for item, data in pairs(espLabels) do
        if data.bb then data.bb:Destroy() end
    end
    espLabels = {}
end

local function refreshEsp()
    clearEsp()
    if not draggableFolder then return end
    for _, item in ipairs(draggableFolder:GetChildren()) do
        if item:IsA("Model") then
            createEsp(item)
        end
    end
end

local function updateEsp()
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end
    local hrp = player.Character.HumanoidRootPart
    for item, data in pairs(espLabels) do
        if not item or not item.Parent or not data.part or not data.part.Parent then
            if data.bb then data.bb:Destroy() end
            espLabels[item] = nil
            continue
        end
        local dist = (hrp.Position - data.part.Position).Magnitude
        data.dl.Text = string.format("%.1fm", dist)
    end
end

local function refreshDropdown()
    for _, child in ipairs(scrollFrame:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    selectedItem = nil
    dropdownBtn.Text = "选择物资 ▼"
    if not draggableFolder then return end
    for _, item in ipairs(draggableFolder:GetChildren()) do
        if item:IsA("Model") then
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, 0, 0, 22)
            btn.BackgroundColor3 = Color3.fromRGB(55, 55, 55)
            btn.Text = item.Name
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            btn.TextSize = 12
            btn.Font = Enum.Font.SourceSans
            btn.Parent = scrollFrame
            btn.MouseButton1Click:Connect(function()
                selectedItem = item
                dropdownBtn.Text = item.Name .. " ▼"
                scrollFrame.Visible = false
            end)
        end
    end
end

local function pullItem()
    if not selectedItem or not selectedItem.Parent then
        statusLabel.Text = "状态: 没有"
        statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        return
    end
    statusLabel.Text = "状态: 已找到，正在拉取"
    statusLabel.TextColor3 = Color3.fromRGB(80, 255, 80)
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then
        statusLabel.Text = "状态: 角色未加载"
        statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        return
    end
    local hrp = char.HumanoidRootPart
    local targetCFrame = hrp.CFrame * CFrame.new(0, 0, -4)
    pcall(function()
        selectedItem:PivotTo(targetCFrame)
    end)
end

espToggle.MouseButton1Click:Connect(function()
    espEnabled = not espEnabled
    if espEnabled then
        espToggle.Text = "透视: 开"
        espToggle.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
        refreshEsp()
    else
        espToggle.Text = "透视: 关"
        espToggle.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        clearEsp()
    end
end)

dropdownBtn.MouseButton1Click:Connect(function()
    scrollFrame.Visible = not scrollFrame.Visible
end)

pullBtn.MouseButton1Click:Connect(function()
    pullItem()
end)

refreshBtn.MouseButton1Click:Connect(function()
    refreshDropdown()
    local count = 0
    if draggableFolder then
        for _, item in ipairs(draggableFolder:GetChildren()) do
            if item:IsA("Model") then count = count + 1 end
        end
    end
    statusLabel.Text = "状态: 已刷新，共" .. count .. "个物资"
    statusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
end)

RunService.RenderStepped:Connect(function()
    if espEnabled then
        updateEsp()
    end
end)

if draggableFolder then
    draggableFolder.ChildAdded:Connect(function(child)
        if espEnabled and child:IsA("Model") then
            task.wait(0.3)
            createEsp(child)
        end
    end)
    draggableFolder.ChildRemoved:Connect(function(child)
        if espLabels[child] then
            if espLabels[child].bb then
                espLabels[child].bb:Destroy()
            end
            espLabels[child] = nil
        end
    end)
end

refreshDropdown()
