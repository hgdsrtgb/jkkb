local function translateName(name)
    if type(name) ~= "string" then return name end
    local lower = string.lower(name)
    if nameTranslations[lower] then
        return nameTranslations[lower]
    end
    for eng, chn in pairs(nameTranslations) do
        if string.find(lower, eng, 1, true) then
            return chn
        end
    end
    return name
end

local function getMinKG()
    local ok, v = pcall(function() return Options.PlantESP_MinKG.Value end)
    if ok and type(v) == "number" then return v end
    return 0
end

local function getMaxKG()
    local ok, v = pcall(function() return Options.PlantESP_MaxKG.Value end)
    if ok and type(v) == "number" then return v end
    return 1000
end

local function passFilter(fruit)
    local w = getWeight(fruit)
    if w == nil then return true end
    return w >= getMinKG() and w <= getMaxKG()
end

