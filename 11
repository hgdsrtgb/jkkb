local ESPFolder = nil
local ESPConnections = {}
local ESPEnabled = false
local ESPTrans = 0.3

local function ClearESP()
    for _, con in pairs(ESPConnections) do
        pcall(function() con:Disconnect() end)
    end
    ESPConnections = {}
    if ESPFolder then
        pcall(function() ESPFolder:Destroy() end)
    end
    ESPFolder = nil
end

local function UpdateESPTransparency(trans)
    if not ESPFolder then return end
    for _, v in pairs(ESPFolder:GetDescendants()) do
        if v:IsA("BoxHandleAdornment") then
            v.Transparency = trans
        end
    end
end

local function CreateESP(plr)
    if plr == player then return end
    task.spawn(function()
        if ESPFolder then
            local old = ESPFolder:FindFirstChild("esp_" .. plr.Name)
            if old then old:Destroy() end
        end
        repeat task.wait() until plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character:FindFirstChildOfClass("Humanoid")
        local plrChar = plr.Character
        if not ESPFolder then return end
        local espFolder = Instance.new("Folder")
        espFolder.Name = "esp_" .. plr.Name
        espFolder.Parent = ESPFolder
        for _, v in pairs(plrChar:GetChildren()) do
            if v:IsA("BasePart") and (v.Name == "Left Leg" or v.Name == "Left Arm" or v.Name == "Right Leg" or v.Name == "Right Arm" or v.Name == "Torso" or v.Name == "Head") then
                local box = Instance.new("BoxHandleAdornment")
                box.Name = "box_" .. plr.Name
                box.Adornee = v
                box.AlwaysOnTop = true
                box.ZIndex = 10
                box.Size = v.Size
                box.Transparency = ESPTrans
                local teamColor = "Bright green"
                if plrChar.Parent and plrChar.Parent.Name == "Killer" then
                    teamColor = "Bright red"
                elseif plrChar.Parent and plrChar.Parent.Name == "Ghost" then
                    teamColor = "White"
                end
                box.Color = BrickColor.new(teamColor)
                box.Parent = espFolder
                if v.Name == "Head" then
                    local bill = Instance.new("BillboardGui")
                    bill.Adornee = v
                    bill.AlwaysOnTop = true
                    bill.Size = UDim2.new(0, 80, 0, 50)
                    bill.StudsOffset = Vector3.new(0, 0.2, 0)
                    bill.Parent = espFolder
                    local text = Instance.new("TextLabel")
                    text.BackgroundTransparency = 1
                    text.Position = UDim2.new(0, 0, 0, -50)
                    text.Size = UDim2.new(0, 80, 0, 80)
                    text.Font = Enum.Font.SourceSansSemibold
                    text.TextSize = 15
                    text.TextColor3 = Color3.new(1, 1, 1)
                    text.TextStrokeTransparency = 0
                    text.TextYAlignment = Enum.TextYAlignment.Bottom
                    text.Parent = bill
                    task.spawn(function()
                        while bill and bill.Parent do
                            pcall(function()
                                text.Text = "Name: " .. plr.Name .. "\nHealth: " .. plrChar.Humanoid.Health
                            end)
                            task.wait(0.05)
                        end
                    end)
                end
            end
        end
        local charCon = plr.CharacterAdded:Connect(function()
            if espFolder then espFolder:Destroy() end
            repeat task.wait(1.25) until plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character:FindFirstChildOfClass("Humanoid")
            CreateESP(plr)
            charCon:Disconnect()
        end)
        table.insert(ESPConnections, charCon)
    end)
end

local VisualGroup = Tabs.Main:AddRightGroupbox("透视功能")

VisualGroup:AddToggle("透视", {
    Text = "透视",
    Default = false,
    Callback = function(Value)
        ESPEnabled = Value
        if Value then
            if not game:GetService("CoreGui"):FindFirstChild("DOD_ESP") then
                ESPFolder = Instance.new("Folder")
                ESPFolder.Name = "DOD_ESP"
                ESPFolder.Parent = game:GetService("CoreGui")
            else
                ESPFolder = game:GetService("CoreGui"):FindFirstChild("DOD_ESP")
            end
            for _, plr in pairs(Players:GetPlayers()) do
                if plr ~= player then
                    CreateESP(plr)
                end
            end
            local con1 = Players.PlayerAdded:Connect(function(plr)
                if ESPEnabled then
                    CreateESP(plr)
                end
            end)
            local con2 = Players.PlayerRemoving:Connect(function(plr)
                if ESPFolder then
                    local f = ESPFolder:FindFirstChild("esp_" .. plr.Name)
                    if f then f:Destroy() end
                end
            end)
            table.insert(ESPConnections, con1)
            table.insert(ESPConnections, con2)
        else
            ClearESP()
        end
    end
})

VisualGroup:AddSlider("透视透明度", {
