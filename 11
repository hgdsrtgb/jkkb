local function pullAllItems()
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then
        Library:Notify({Title = "拉取", Description = "角色未加载", Time = 3})
        return
    end
    local hrp = char.HumanoidRootPart
    local items = {}
    if draggableFolder then
        for _, item in ipairs(draggableFolder:GetChildren()) do
            if item:IsA("Model") then
                table.insert(items, item)
            end
        end
    end
    if #items == 0 then
        Library:Notify({Title = "拉取", Description = "没有物资", Time = 3})
        return
    end
    Library:Notify({Title = "拉取", Description = "已找到，正在拉取 " .. #items .. " 个物资", Time = 3})
    for i, item in ipairs(items) do
        pcall(function()
            local angle = (i - 1) * (math.pi * 2 / math.max(#items, 1))
            local ring = math.floor((i - 1) / 12)
            local dist = 4 + ring * 4
            local offset = CFrame.new(math.cos(angle) * dist, 0, math.sin(angle) * dist)
            item:PivotTo(hrp.CFrame * offset)
        end)
    end
end

PullGroup:AddButton("拉取全部物资", function()
    pullAllItems()
end)

local bulletAimEnabled = false

local function getEnemies()
    local enemies = {}
    for _, model in ipairs(Workspace:GetDescendants()) do
        if model:IsA("Model") and model:FindFirstChildOfClass("Humanoid") then
            local isPlayer = false
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr.Character == model then
                    isPlayer = true
                    break
                end
            end
            if not isPlayer then
                table.insert(enemies, model)
            end
        end
    end
    return enemies
end

local function getNearestEnemyPart(fromPos)
    local enemies = getEnemies()
    local nearest = nil
    local minDist = math.huge
    for _, enemy in ipairs(enemies) do
        local part = enemy:FindFirstChild("HumanoidRootPart") or enemy:FindFirstChild("Head") or enemy:FindFirstChildWhichIsA("BasePart")
        if part then
            local d = (part.Position - fromPos).Magnitude
            if d < minDist then
                minDist = d
                nearest = part
            end
        end
    end
    return nearest
end

local trackedConns = {}

local function trackBullet(obj)
    if obj:GetAttribute("BulletTracked") then return end
    local nearest = getNearestEnemyPart(obj.Position)
    if not nearest then return end
    obj:SetAttribute("BulletTracked", true)
    pcall(function()
        obj.Size = obj.Size * 4
    end)
    local conn
    conn = RunService.Heartbeat:Connect(function()
        if not obj or not obj.Parent then
            conn:Disconnect()
            return
        end
        if not bulletAimEnabled then
            conn:Disconnect()
            return
        end
        local target = getNearestEnemyPart(obj.Position)
        if target then
            obj.CFrame = CFrame.new(obj.Position, target.Position)
            obj.Velocity = (target.Position - obj.Position).Unit * math.max(obj.Velocity.Magnitude, 200)
        end
    end)
    table.insert(trackedConns, conn)
end

RunService.Heartbeat:Connect(function()
    if not bulletAimEnabled then
        for _, conn in ipairs(trackedConns) do
            pcall(function() conn:Disconnect() end)
        end
        trackedConns = {}
        return
    end
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and not obj:GetAttribute("BulletTracked") then
            local vel = obj.Velocity.Magnitude
            if vel > 40 and vel < 600 then
                trackBullet(obj)
            end
        end
    end
end)

