end)

task.spawn(function()
    while true do
        if espEnabled then
            pcall(function()
                for fruit, data in pairs(espData) do
                    pcall(function()
                        if fruit.Parent and data.label and data.label.Parent then
                            if not passFilter(fruit) then
                                removeESP(fruit)
                            else
                                if data.name == "未知植物" then
                                    data.name = translateName(getPlantName(fruit))
                                end
                                local w = getWeight(fruit)
                                if w then
                                    data.label.Text = data.name .. "\n" .. string.format("%.2fkg", w)
                                else
                                    data.label.Text = data.name
                                end
                            end
                        end
                    end)
                end
            end)
        end
        task.wait(1)
    end
end)
