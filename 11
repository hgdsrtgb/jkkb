local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")

local localPlayer = Players.LocalPlayer
local folderName = "AuctionPriceESP"

_G.AuctionPriceESPLoadId = (_G.AuctionPriceESPLoadId or 0) + 1
local loadId = _G.AuctionPriceESPLoadId

local oldFolder = Workspace:FindFirstChild(folderName)
if oldFolder then
	oldFolder:Destroy()
end

local espFolder = Instance.new("Folder")
espFolder.Name = folderName
espFolder.Parent = Workspace

local entries = {}

local function getPlayerGui()
	return localPlayer and localPlayer:FindFirstChildOfClass("PlayerGui")
end

local function findAuctionFrame()
	local playerGui = getPlayerGui()
	return playerGui and playerGui:FindFirstChild("Auction")
end

local function findAuctionStand()
	return Workspace:FindFirstChild("AuctionStand", true) or Workspace:FindFirstChild("AuctioneerStand", true)
end

local function getStandInfo()
	local stand = findAuctionStand()
	if not stand then
		return nil
	end
	if stand:IsA("Model") then
		local success, boundingCFrame, boundingSize = pcall(function()
			return stand:GetBoundingBox()
		end)
		if success and boundingCFrame and boundingSize then
			return boundingCFrame, boundingSize
		end
	end
	local part = stand:IsA("BasePart") and stand or stand:FindFirstChildWhichIsA("BasePart", true)
	if part then
		return part.CFrame, part.Size
	end
	return nil
end

local function getLots()
	local lots = {}
	local auction = findAuctionFrame()
	if not auction then
		return lots
	end
	local scrollingFrame = auction:FindFirstChildWhichIsA("ScrollingFrame", true)
	local searchRoot = scrollingFrame or auction
	for _, object in ipairs(searchRoot:GetDescendants()) do
		if object:IsA("Frame") and string.match(object.Name, "^Lot_auction:") then
			table.insert(lots, object)
		end
	end
	table.sort(lots, function(a, b)
		local aIndex = tonumber(string.match(a.Name, ":(%d+)$")) or 0
		local bIndex = tonumber(string.match(b.Name, ":(%d+)$")) or 0
		if aIndex == bIndex then
			return a.Name < b.Name
		end
		return aIndex < bIndex
	end)
	return lots
end

local function readAttribute(root, names)
	for _, attributeName in ipairs(names) do
		local value = root:GetAttribute(attributeName)
		if value ~= nil and tostring(value) ~= "" then
			return tostring(value)
		end
	end
	return nil
end

local function getItemName(lot)
	local attributeName = readAttribute(lot, {"ItemName", "Item", "Name", "DisplayName", "ProductName"})
	if attributeName then
		return attributeName
	end
	local label = lot:FindFirstChild("ItemName", true)
	if label and label:IsA("TextLabel") and label.Text ~= "" then
		return label.Text
	end
	return "未知物品"
end

local function getValuePrice(lot)
	for _, object in ipairs(lot:GetDescendants()) do
		if object:IsA("NumberValue") or object:IsA("IntValue") or object:IsA("StringValue") then
			local lowerName = string.lower(object.Name)
			if string.find(lowerName, "price") or string.find(lowerName, "cost") then
				return tostring(object.Value)
			end
		end
	end
	return nil
end

local function getPriceText(lot)
	local attributePrice = readAttribute(lot, {"Price", "Cost", "ItemPrice", "CurrentPrice", "CurrentBid", "Bid", "Value"})
	if attributePrice then
		return attributePrice
	end
	local valuePrice = getValuePrice(lot)
	if valuePrice then
		return valuePrice
	end
	local bestText = ""
	local bestScore = -math.huge
	for _, object in ipairs(lot:GetDescendants()) do
		if object:IsA("TextLabel") or object:IsA("TextButton") then
			local text = object.Text or ""
			if text ~= "" and string.find(text, "%d") then
				local lowerName = string.lower(object.Name)
				local lowerPath = string.lower(object:GetFullName())
				local score = 0
				if string.find(lowerName, "price") or string.find(lowerName, "cost") then
					score = score + 100
				end
				if string.find(lowerPath, "buybutton") then
					score = score + 90
				end
				if string.find(lowerPath, "robuxbutton") then
					score = score + 80
				end
				if string.find(lowerName, "amount") then
					score = score - 90
				end
				if string.find(lowerName, "stock") or string.find(lowerPath, "out_of_stock") then
					score = score - 120
				end
				if string.find(lowerName, "timer") or string.find(lowerPath, "refreshin") then
					score = score - 130
				end
				if string.find(lowerName, "rarity") then
					score = score - 150
				end
				if string.find(text, "%%") then
					score = score - 80
				end
				if #text <= 30 then
					score = score + 15
				end
				if score > bestScore then
					bestScore = score
					bestText = text
				end
			end
		end
	end
	if bestText == "" then
		return "未找到价格"
	end
	return bestText
end

local function createEntry(lot)
	local part = Instance.new("Part")
	part.Name = lot.Name
	part.Anchored = true
	part.CanCollide = false
	part.CanTouch = false
	part.CanQuery = false
	part.Transparency = 1
	part.Size = Vector3.new(0.1, 0.1, 0.1)
	part.Parent = espFolder

	local billboard = Instance.new("BillboardGui")
	billboard.Name = "PriceESP"
	billboard.Size = UDim2.fromOffset(240, 60)
	billboard.AlwaysOnTop = true
	billboard.MaxDistance = 1000
	billboard.Parent = part

	local label = Instance.new("TextLabel")
	label.Name = "Text"
	label.AnchorPoint = Vector2.new(0.5, 0.5)
	label.Position = UDim2.fromScale(0.5, 0.5)
	label.Size = UDim2.fromScale(1, 1)
	label.BackgroundColor3 = Color3.fromRGB(8, 8, 8)
	label.BackgroundTransparency = 0.2
	label.BorderSizePixel = 0
	label.Font = Enum.Font.GothamBold
	label.TextColor3 = Color3.fromRGB(255, 255, 255)
	label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	label.TextStrokeTransparency = 0.2
	label.TextWrapped = true
	label.TextScaled = true
	label.RichText = false
	label.Parent = billboard

	local textConstraint = Instance.new("UITextSizeConstraint")
	textConstraint.MinTextSize = 10
	textConstraint.MaxTextSize = 18
	textConstraint.Parent = label

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 8)
	corner.Parent = label

	local stroke = Instance.new("UIStroke")
	stroke.Color = Color3.fromRGB(255, 255, 255)
	stroke.Transparency = 0.35
	stroke.Thickness = 1.5
	stroke.Parent = label

	entries[lot] = {
		Part = part,
		Label = label
	}
end

local function removeMissing(seen)
	for lot, entry in pairs(entries) do
		if not seen[lot] or not lot.Parent then
			if entry.Part then
				entry.Part:Destroy()
			end
			entries[lot] = nil
		end
	end
end

local function getEntryPosition(index, total, boundingCFrame, boundingSize)
	local columns = 3
	local row = math.floor((index - 1) / columns)
	local column = (index - 1) % columns
	local itemsInRow = math.min(columns, total - row * columns)
	local horizontal = (column - (itemsInRow - 1) / 2) * 10
	local vertical = 5 - row * 4.5
	local sideOffset = boundingCFrame.RightVector * (boundingSize.X * 0.5 + 7)
	local spreadOffset = boundingCFrame.LookVector * horizontal
	return boundingCFrame.Position + sideOffset + spreadOffset + Vector3.new(0, vertical, 0)
end

local function refresh()
	local boundingCFrame, boundingSize = getStandInfo()
	local lots = getLots()
	local seen = {}
	if boundingCFrame and boundingSize then
		for index, lot in ipairs(lots) do
			seen[lot] = true
			if not entries[lot] then
				createEntry(lot)
			end
			local entry = entries[lot]
			entry.Part.CFrame = CFrame.new(getEntryPosition(index, #lots, boundingCFrame, boundingSize))
			entry.Label.Text = "物品：" .. getItemName(lot) .. "\n价格：" .. getPriceText(lot)
		end
	end
	removeMissing(seen)
end

task.spawn(function()
	while _G.AuctionPriceESPLoadId == loadId do
		pcall(refresh)
		task.wait(0.35)
	end
end)
