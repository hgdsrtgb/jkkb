local function pullItems(category)
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then
        Library:Notify({Title = "拉取", Description = "角色未加载", Time = 3})
        return
    end
    local hrp = char.HumanoidRootPart
    local names = categoryMap[category]
    local items = {}
    if draggableFolder then
        for _, item in ipairs(draggableFolder:GetChildren()) do
            if item:IsA("Model") then
                if not names then
                    table.insert(items, item)
                else
                    for _, n in ipairs(names) do
                        if item.Name == n then
                            table.insert(items, item)
                            break
                        end
                    end
                end
            end
        end
    end
    if #items == 0 then
        Library:Notify({Title = "拉取", Description = "没有物资", Time = 3})
        return
    end
    Library:Notify({Title = "拉取", Description = "已找到，正在拉取 " .. #items .. " 个物资", Time = 3})
    task.spawn(function()
        for i, item in ipairs(items) do
            pcall(function()
                local angle = (i - 1) * (math.pi * 2 / math.max(#items, 1))
                local ring = math.floor((i - 1) / 12)
                local dist = 4 + ring * 4
                local offset = CFrame.new(math.cos(angle) * dist, 0, math.sin(angle) * dist)
                item:PivotTo(hrp.CFrame * offset)
            end)
            if i % 10 == 0 then
                RunService.Heartbeat:Wait()
            end
        end
    end)
end

PullGroup:AddButton("拉取选定分类", function()
    pullItems(selectedCategory)
end)

PullGroup:AddButton("拉取全部物资", function()
    pullItems("全部物资")
end)

local bulletAimEnabled = false
local enemyCache = {}
local lastCacheTime = 0

local function refreshEnemyCache()
    enemyCache = {}
    for _, model in ipairs(Workspace:GetDescendants()) do
        if model:IsA("Model") and model:FindFirstChildOfClass("Humanoid") then
            local isPlayer = false
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr.Character == model then
                    isPlayer = true
                    break
                end
            end
            if not isPlayer then
                table.insert(enemyCache, model)
            end
        end
    end
    lastCacheTime = tick()
end

local function getEnemies()
    if tick() - lastCacheTime > 1 then
        refreshEnemyCache()
    end
    return enemyCache
end

local function getNearestEnemyPart(fromPos)
    local enemies = getEnemies()
    local nearest = nil
    local minDist = math.huge
    for _, enemy in ipairs(enemies) do
        local part = enemy:FindFirstChild("HumanoidRootPart") or enemy:FindFirstChild("Head") or enemy:FindFirstChildWhichIsA("BasePart")
        if part then
            local d = (part.Position - fromPos).Magnitude
            if d < minDist then
                minDist = d
                nearest = part
            end
        end
    end
    return nearest
end

local trackedBullets = {}
local lastScan = 0

RunService.Heartbeat:Connect(function()
    if not bulletAimEnabled then
        for i = #trackedBullets, 1, -1 do
            trackedBullets[i] = nil
        end
        return
    end

    local now = tick()
    if now - lastScan >= 0.15 then
        lastScan = now
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("BasePart") and not obj:GetAttribute("BulletTracked") then
                local vel = obj.Velocity.Magnitude
                if vel > 40 and vel < 600 then
                    obj:SetAttribute("BulletTracked", true)
                    pcall(function()
                        obj.Size = obj.Size * 4
                    end)
                    table.insert(trackedBullets, obj)
                end
            end
        end
    end

    for i = #trackedBullets, 1, -1 do
        if not trackedBullets[i] or not trackedBullets[i].Parent then
            table.remove(trackedBullets, i)
        end
    end

    if #trackedBullets == 0 then return end

    local target = getNearestEnemyPart(player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character.HumanoidRootPart.Position or Vector3.new())
    if not target then return end

    for _, bullet in ipairs(trackedBullets) do
        pcall(function()
            bullet.CFrame = CFrame.new(bullet.Position, target.Position)
            bullet.Velocity = (target.Position - bullet.Position).Unit * math.max(bullet.Velocity.Magnitude, 200)
        end)
    end
end)

AimGroup:AddToggle("BulletAim", {
