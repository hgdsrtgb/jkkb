local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer

local RarityColors = {
	common = Color3.fromRGB(0, 255, 0),
	uncommon = Color3.fromRGB(0, 170, 255),
	rare = Color3.fromRGB(255, 255, 0),
	epic = Color3.fromRGB(255, 0, 0),
	legendary = Color3.fromRGB(255, 200, 0),
	mythic = Color3.fromRGB(170, 0, 255),
	divine = Color3.fromRGB(170, 0, 255),
	secret = Color3.fromRGB(170, 0, 255)
}

local DefaultColor = Color3.fromRGB(255, 255, 255)

local espEnabled = false
local tracked = {}
local watchedFolders = {}
local connections = {}
local heartbeatConn = nil
local heartbeatAcc = 0

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "PetESPGui"
screenGui.ResetOnSpawn = false
screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
screenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

local toggleBtn = Instance.new("TextButton")
toggleBtn.Size = UDim2.new(0, 130, 0, 40)
toggleBtn.Position = UDim2.new(0, 15, 0.5, -20)
toggleBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
toggleBtn.TextColor3 = Color3.fromRGB(255, 80, 80)
toggleBtn.Text = "宠物透视: 关"
toggleBtn.Font = Enum.Font.GothamBold
toggleBtn.TextSize = 15
toggleBtn.Active = true
toggleBtn.Draggable = true
toggleBtn.Parent = screenGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 8)
corner.Parent = toggleBtn

local stroke = Instance.new("UIStroke")
stroke.Color = Color3.fromRGB(255, 255, 255)
stroke.Thickness = 1
stroke.Transparency = 0.6
stroke.Parent = toggleBtn

local function getRarityColor(rarity)
	if not rarity then
		return DefaultColor
	end
	local key = string.lower(tostring(rarity))
	for name, color in pairs(RarityColors) do
		if string.find(key, name) then
			return color
		end
	end
	return DefaultColor
end

local function getPetInfo(model)
	local info = {}
	local attrs = model:GetAttributes()
	for k, v in pairs(attrs) do
		local lk = string.lower(k)
		if string.find(lk, "rarity") then
			info.Rarity = tostring(v)
		elseif string.find(lk, "weight") then
			info.Weight = tostring(v)
		elseif string.find(lk, "age") then
			info.Age = tostring(v)
		elseif string.find(lk, "name") or string.find(lk, "type") or lk == "pet" then
			if not info.Name then
				info.Name = tostring(v)
			end
		end
	end
	for _, child in ipairs(model:GetChildren()) do
		if child:IsA("StringValue") or child:IsA("NumberValue") or child:IsA("IntValue") then
			local lk = string.lower(child.Name)
			if string.find(lk, "rarity") and not info.Rarity then
				info.Rarity = tostring(child.Value)
			elseif string.find(lk, "weight") and not info.Weight then
				info.Weight = tostring(child.Value)
			elseif string.find(lk, "age") and not info.Age then
				info.Age = tostring(child.Value)
			elseif (string.find(lk, "name") or string.find(lk, "type")) and not info.Name then
				info.Name = tostring(child.Value)
			end
		end
	end
	return info
end

local function buildText(model)
	local data = tracked[model]
	if not data then
		return ""
	end
	local info = data.Info
	local lines = {}
	local nameLine = info.Name or "宠物"
	if info.Rarity then
		nameLine = nameLine .. " [" .. info.Rarity .. "]"
	end
	table.insert(lines, nameLine)
	if info.Age then
		table.insert(lines, "年龄: " .. info.Age)
	end
	if info.Weight then
		table.insert(lines, "重量: " .. info.Weight .. "kg")
	end
	table.insert(lines, "距离: " .. data.Distance .. "m")
	return table.concat(lines, "\n")
end

local function addESP(model)
	if tracked[model] then
		return
	end
	if not model:IsA("Model") then
		return
	end
	local info = getPetInfo(model)
	local color = getRarityColor(info.Rarity)
	local highlight = Instance.new("Highlight")
	highlight.Name = "PetESPHighlight"
	highlight.FillColor = color
	highlight.OutlineColor = color
	highlight.FillTransparency = 0.55
	highlight.OutlineTransparency = 0
	highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	highlight.Adornee = model
	highlight.Parent = model
	local billboard = Instance.new("BillboardGui")
	billboard.Name = "PetESPBillboard"
	billboard.Size = UDim2.new(0, 220, 0, 80)
	billboard.StudsOffsetWorldSpace = Vector3.new(0, 3.5, 0)
	billboard.AlwaysOnTop = true
	billboard.Adornee = model
	billboard.Parent = model
	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, 0, 1, 0)
	label.BackgroundTransparency = 1
	label.TextColor3 = color
	label.TextStrokeTransparency = 0.3
	label.Font = Enum.Font.GothamBold
	label.TextSize = 14
	label.Text = ""
	label.Parent = billboard
	tracked[model] = {
		Info = info,
		Highlight = highlight,
		Billboard = billboard,
		Label = label,
		Distance = "?"
	}
end

local function removeESP(model)
	local data = tracked[model]
	if not data then
		return
	end
	if data.Highlight then
		data.Highlight:Destroy()
	end
	if data.Billboard then
		data.Billboard:Destroy()
	end
	tracked[model] = nil
end

local function isPetModel(obj)
	return obj:IsA("Model") and obj:FindFirstChild("HumanoidRootPart") ~= nil
end

local function onFolderChild(obj)
	if isPetModel(obj) then
		addESP(obj)
	elseif obj:IsA("Folder") then
		watchFolder(obj)
	end
end

function watchFolder(folder)
	if watchedFolders[folder] then
		return
	end
	watchedFolders[folder] = true
	for _, child in ipairs(folder:GetChildren()) do
		onFolderChild(child)
	end
	table.insert(connections, folder.ChildAdded:Connect(onFolderChild))
	table.insert(connections, folder.ChildRemoved:Connect(function(obj)
		if tracked[obj] then
			removeESP(obj)
		end
	end))
end

local function scanContainers()
	for _, obj in ipairs(Workspace:GetDescendants()) do
		if obj:IsA("Folder") and string.find(string.lower(obj.Name), "pets") then
			watchFolder(obj)
		end
	end
end

local function startHeartbeat()
	if heartbeatConn then
		return
	end
	heartbeatConn = RunService.Heartbeat:Connect(function(dt)
		heartbeatAcc = heartbeatAcc + dt
		if heartbeatAcc < 0.15 then
			return
		end
		heartbeatAcc = 0
		local char = LocalPlayer.Character
		local hrp = char and char:FindFirstChild("HumanoidRootPart")
		if not hrp then
			return
		end
		local myPos = hrp.Position
		for model, data in pairs(tracked) do
			if model.Parent then
				local ok, pivot = pcall(function()
					return model:GetPivot()
				end)
				if ok and pivot then
					data.Distance = tostring(math.floor((pivot.Position - myPos).Magnitude))
					data.Label.Text = buildText(model)
				end
			else
				removeESP(model)
			end
		end
	end)
end

local function stopAll()
	if heartbeatConn then
		heartbeatConn:Disconnect()
		heartbeatConn = nil
	end
	for _, conn in ipairs(connections) do
		conn:Disconnect()
	end
	table.clear(connections)
	table.clear(watchedFolders)
	for model in pairs(tracked) do
		removeESP(model)
	end
end

Workspace.DescendantAdded:Connect(function(obj)
	if espEnabled and obj:IsA("Folder") and string.find(string.lower(obj.Name), "pets") then
		watchFolder(obj)
	end
end)

toggleBtn.MouseButton1Click:Connect(function()
	espEnabled = not espEnabled
	if espEnabled then
		toggleBtn.Text = "宠物透视: 开"
		toggleBtn.TextColor3 = Color3.fromRGB(80, 255, 80)
		scanContainers()
		startHeartbeat()
	else
		toggleBtn.Text = "宠物透视: 关"
		toggleBtn.TextColor3 = Color3.fromRGB(255, 80, 80)
		stopAll()
	end
end)
